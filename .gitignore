# =============================================================================
# ECLIPSE — Embedded Cryptography Lightweight and Post-quantum IoT
# System Performance Evaluation
# .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# C build artifacts
# -----------------------------------------------------------------------------
*.d
*.o
*.ko
*.obj
*.ilk
*.map
*.exp
*.gch
*.pch
*.lib
*.a
*.la
*.lo
*.dll
*.so
*.so.*
*.dylib
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex
*.elf
*.dSYM/
*.su
*.idb
*.pdb
*.dwo
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# -----------------------------------------------------------------------------
# CMake / build system
# -----------------------------------------------------------------------------
build/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt
!cmake/*.cmake
*.ninja
.ninja_*
compile_commands.json
_deps/

# -----------------------------------------------------------------------------
# Pico SDK (fetched at configure time, not committed)
# -----------------------------------------------------------------------------
pico-sdk/
picotool/

# -----------------------------------------------------------------------------
# Benchmark results
# Keep results/ and results/archived/ — these are the primary research output.
# Exclude nothing under results/ so all CSVs are tracked.
# -----------------------------------------------------------------------------
plots/

# -----------------------------------------------------------------------------
# Generated images and plots (reproducible from results CSVs via plot_results.py)
# -----------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.svg

# PDFs are excluded globally EXCEPT the thesis draft which lives at the repo root
# or in a doc/ folder — add explicit exceptions below if needed.
*.pdf

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
.eggs/
.venv/
venv/
env/

# -----------------------------------------------------------------------------
# OS / editor files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# VS Code — keep c_cpp_properties.json (IntelliSense config) but ignore
# everything else (launch configs, settings, extensions list)
.vscode/*
!.vscode/c_cpp_properties.json

# JetBrains / CLion
.idea/
cmake-build-*/

# Vim / Emacs swap files
*.swp
*.swo
*~
\#*\#
.\#*
